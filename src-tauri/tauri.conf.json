{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SilentWrite",
  "version": "0.1.0",
  "identifier": "com.foryesify.silentwrite",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "SilentWrite",
        "width": 800,
        "height": 600,
        "decorations": false,
        "transparent": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "nsis",
    "icon": ["icons/favicon.png", "icons/icon128x128.ico", "icons/icon64x64.ico"]
  }
}
